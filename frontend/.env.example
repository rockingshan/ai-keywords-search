# Environment Configuration Example
# Copy this file to .env.local for local development

# PHP Backend API URL
# For Apache on port 8181 (Laragon):
VITE_API_URL=http://localhost:8181/keywordsearch/api

# For Apache on standard port 80:
# VITE_API_URL=http://localhost/keywordsearch/api

# For local development with different port:
# VITE_API_URL=http://localhost:8080/keywordsearch/api
